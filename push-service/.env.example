# ---------------------------------------------------------------------------
# Kura push-service configuration
# Copy to .env. The defaults below run in DRY-RUN mode (no Apple certs needed).
# ---------------------------------------------------------------------------

# Where the VERA-cloud API lives (used to create check-in sessions).
# Leave blank to also stub session creation locally (handy before VERA is wired up).
VERA_API_BASE=
# Optional bearer/api key if VERA-cloud requires auth on /session/start
VERA_API_KEY=

# --- Apple Push Notification service (APNs) ---
# DRY_RUN=true  -> pushes are logged, not sent. No Apple account needed. Great for dev/tests.
# DRY_RUN=false -> requires the four APNS_* values below (token-based / .p8 auth key).
DRY_RUN=true

APNS_USE_SANDBOX=true            # true => api.sandbox.push.apple.com (dev/TestFlight builds)
APNS_TEAM_ID=                    # 10-char Apple Developer Team ID
APNS_KEY_ID=                     # 10-char Key ID for your APNs auth key
APNS_BUNDLE_ID=com.example.kura  # your app bundle identifier (the APNs topic)
APNS_AUTH_KEY_PATH=              # path to AuthKey_XXXXXXXXXX.p8 (NEVER commit this file)

# --- Storage ---
# SQLAlchemy database URL. Empty => local SQLite file (./data/kura.db).
# For persistence in the cloud, set a Postgres/Neon URL, e.g.:
#   DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=
# (legacy, unused once DB is on)
DEVICE_STORE_PATH=:memory:

# --- Provider API auth (very simple shared secret for the beta) ---
# Providers must send header  X-Provider-Key: <this value>  to start a check-in.
# Empty => auth disabled (dev only). The console now also supports per-clinician
# login; seed accounts with `python -m scripts.seed_clinician`.
PROVIDER_API_KEY=

# --- Clinician sessions ---
# Secret used to sign clinician login cookies. Empty => falls back to PROVIDER_API_KEY.
# Set a long random value in production:  python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=
SESSION_TTL_HOURS=12

# --- Emergency (Tier-1) email alerts ---
# All optional. If SMTP_HOST / ALERT_EMAIL_FROM / ALERT_EMAIL_TO aren't all set,
# alerting silently no-ops (safe to ship dark, arm later via Azure app settings).
# Only Tier-1 (emergency/BE-FAST) flags trigger an email; Tier-2 stays in the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=                  # comma-separated recipients (on-call clinician[s])
# Public console URL, used to deep-link from the alert email (e.g. https://kura-push.azurewebsites.net)
CONSOLE_BASE_URL=
