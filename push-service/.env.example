# ---------------------------------------------------------------------------
# Kura push-service configuration
# Copy to .env. The defaults below run in DRY-RUN mode (no Apple certs needed).
# ---------------------------------------------------------------------------

# Where the VERA-cloud API lives (used to create check-in sessions).
# Leave blank to also stub session creation locally (handy before VERA is wired up).
VERA_API_BASE=
# Optional bearer/api key if VERA-cloud requires auth on /session/start
VERA_API_KEY=

# --- Apple Push Notification service (APNs) ---
# DRY_RUN=true  -> pushes are logged, not sent. No Apple account needed. Great for dev/tests.
# DRY_RUN=false -> requires the four APNS_* values below (token-based / .p8 auth key).
DRY_RUN=true

APNS_USE_SANDBOX=true            # true => api.sandbox.push.apple.com (dev/TestFlight builds)
APNS_TEAM_ID=                    # 10-char Apple Developer Team ID
APNS_KEY_ID=                     # 10-char Key ID for your APNs auth key
APNS_BUNDLE_ID=com.example.kura  # your app bundle identifier (the APNs topic)
APNS_AUTH_KEY_PATH=              # path to AuthKey_XXXXXXXXXX.p8 (NEVER commit this file)

# --- Storage ---
# Path to a JSON file used as the simple device registry. ":memory:" keeps it in RAM.
DEVICE_STORE_PATH=:memory:

# --- Provider API auth (very simple shared secret for the beta) ---
# Providers must send header  X-Provider-Key: <this value>  to start a check-in.
# Empty => auth disabled (dev only).
PROVIDER_API_KEY=
